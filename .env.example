# 数据库连接字符串
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=music
# 示例: DATABASE_URL=postgresql://user:password@localhost:5432/mydb?schema=public
DATABASE_URL=postgresql://postgres:postgres@db:5432/music?schema=public

# 管理员后台 JWT/会话密钥
ADMIN_SECRET=change-me-in-production

# 网站域名，用于生成邮件中的链接
SITE_HOST=http://localhost:3000

# Nuxt 开发服务器端口 (可选)
NUXT_PORT=3000

# 网盘链接检测 API 地址，https://github.com/Lampon/PanCheck，需要先部署 PanCheck 服务
PANCHECK_API=

# 网盘链接检测 API 管理员密码
PANCHECK_API_PASSWORD=

# 邮件服务配置（用于反馈处理完成后通知用户）
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=下歌吧
