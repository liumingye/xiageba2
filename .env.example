# 数据库连接字符串
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=music
# 示例: DATABASE_URL=postgresql://user:password@localhost:5432/mydb?schema=public
DATABASE_URL=postgresql://postgres:postgres@db:5432/music?schema=public

# 管理员后台 JWT/会话密钥
ADMIN_SECRET=change-me-in-production

# Nuxt 开发服务器端口 (可选)
NUXT_PORT=3000
