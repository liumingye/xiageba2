generator client {
  provider      = "prisma-client-js"
  output        = "./generated"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(cuid(2))
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
}

model Feedback {
  id          String         @id @default(cuid(2))
  musicId     String
  musicTitle  String
  musicArtist String
  type        FeedbackType
  description String         @default("")
  email       String         @default("")
  status      FeedbackStatus @default(PENDING)
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime?       @updatedAt

  @@index([createdAt])
  @@index([musicId])
  @@index([status])
}

model Music {
  id           String                   @id @default(cuid(2))
  title        String
  artist       String
  album        String
  cover        String
  lyrics       String
  playUrl      String
  downloads    String                   @default("[]")
  viewCount    Int                      @default(0)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime?                @updatedAt
  searchVector Unsupported("tsvector")?

  @@index([createdAt])
  @@index([viewCount])
  @@index([searchVector], type: Gin)
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  image     String    @default("")
  sort      Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  @@index([sort])
}

model Source {
  id           String                   @id @default(cuid(2))
  cid          Int?
  title        String
  url          String
  fid          String?
  description  String                   @default("")
  menu         String                   @default("")
  status       Int                      @default(1)
  invalidNum   Int                      @default(0)
  isTemp       Boolean                  @default(false)
  isSelf       Boolean                  @default(false)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime?                @updatedAt
  searchVector Unsupported("tsvector")?

  @@index([cid])
  @@index([createdAt])
  @@index([status])
  @@index([isSelf])
  @@index([searchVector], type: Gin)
}

model Config {
  key   String @id
  value String @default("")
}

model ApiList {
  id           String   @id @default(cuid(2))
  name         String
  type         String   @default("api")
  url          String
  method       String   @default("GET")
  headers      String   @default("{}")
  fixed_params String   @default("{}")
  field_map    String   @default("{}")
  count        Int      @default(10)
  html_item    String   @default("")
  html_title   String   @default("")
  html_url     Int      @default(0)
  html_type    String   @default("")
  html_url2    String   @default("")
  weight       Int      @default(0)
  status       Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([weight])
}

enum FeedbackStatus {
  PENDING
  DONE
}

enum FeedbackType {
  BROKEN_LINK
  WRONG_CONTENT
  WRONG_CODE
  WRONG_QUALITY
  WRONG_INFO
}
