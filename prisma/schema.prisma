generator client {
  provider      = "prisma-client-js"
  output        = "./generated"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Music {
  id           String   @id @default(cuid(2))
  title        String
  artist       String
  album        String
  cover        String
  lyrics       String
  playUrl      String
  downloads    String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // 生成 tsvector 虚拟列，存储三个字段合并文本
  searchVector Unsupported("tsvector")?
  
  @@index([searchVector], type: Gin)
  @@index([createdAt])
}

model Admin {
  id        String   @id @default(cuid(2))
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
